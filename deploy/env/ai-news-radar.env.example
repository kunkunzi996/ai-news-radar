# Copy this file to /etc/ai-news-radar.env on the server.
# Keep the real file outside the repository and protect it with chmod 600.

PYTHONIOENCODING=utf-8
PYTHONUNBUFFERED=1
RADAR_SOURCE_SCOPE=tested_creator_sources

# Optional: use a private dashboard-exported source config.
# RADAR_SOURCE_CONFIG=/opt/ai-news-radar/sources.config.json

# Optional: Bilibili login cookie file.
# Put the cookie file outside the repository, for example:
# BILIBILI_COOKIE_FILE=/etc/ai-news-radar/bilibili-cookies.txt

# Optional: private OPML as base64 text. Prefer this over committing feeds/follow.opml.
# FOLLOW_OPML_B64=

# Optional: local MediaCrawler JSONL bridges. These paths must exist on the server.
# MEDIACRAWLER_DOUYIN_ENABLED=1
# MEDIACRAWLER_DOUYIN_JSONL=/var/lib/mediacrawler/douyin/creator_contents_latest.jsonl
# MEDIACRAWLER_DOUYIN_SOURCE_NAME=Douyin creators
# MEDIACRAWLER_XHS_ENABLED=1
# MEDIACRAWLER_XHS_JSONL=/var/lib/mediacrawler/xhs/creator_contents_latest.jsonl
# MEDIACRAWLER_XHS_SOURCE_NAME=Xiaohongshu creators

# Optional: WeWe RSS sidecar, if it runs on the same server or a trusted private host.
# WEWE_RSS_ENABLED=1
# WEWE_RSS_BASE_URL=http://127.0.0.1:4000
# WEWE_RSS_FEEDS=AccountName:FEED_ID

# Optional paid/API-backed sources. Leave disabled unless you understand the cost.
# SOCIALDATA_ENABLED=0
# SOCIALDATA_API_KEY=
# TIKHUB_ENABLED=0
# TIKHUB_API_KEY=
# X_API_ENABLED=0
# X_BEARER_TOKEN=
# AGENTMAIL_API_KEY=
# AGENTMAIL_INBOX_ID=
